# 数据集文件（太大，不上传）
datasets/
*.csv
Flowers in Pots.csv

# 预训练模型（会自动下载，不上传）
*.pt
!runs/**/*.pt

# 训练输出（每次训练结果不同）
runs/

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.so

# 虚拟环境
.venv/
venv/
env/
.env/

# IDE 配置
.vscode/
.idea/
.kkcode/

# 系统文件
.DS_Store
Thumbs.db

# 临时文件
*.tmp
*.log

# 训练时下载的预训练权重
yolo*.pt

# 本地清洗报告
cleaning_reports/
